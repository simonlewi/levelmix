# syntax=docker/dockerfile:1

# Build stage
FROM golang:1.24-alpine AS builder

# Install build dependencies
RUN apk add --no-cache git openssh-client

# Configure SSH for GitHub access
RUN mkdir -p -m 0700 ~/.ssh && ssh-keyscan github.com >> ~/.ssh/known_hosts

# Set working directory
WORKDIR /app

# Clone the private enterprise repo using deploy key
RUN --mount=type=ssh git clone git@github.com:simonlewi/levelmix-enterprise.git /app/enterprise

# Copy source code first
COPY . .

# Add enterprise module dependency and point to the local clone
# (must be after COPY . . to avoid go.mod being overwritten)
RUN go mod edit \
    -require=github.com/simonlewi/levelmix-enterprise@v0.0.0 \
    -replace=github.com/simonlewi/levelmix-enterprise=/app/enterprise

# Download dependencies (including enterprise's transitive deps)
RUN go mod tidy && go mod download

# Accept build argument for git commit hash
ARG GIT_COMMIT=dev

# Build the web server with git commit hash injected
RUN CGO_ENABLED=0 GOOS=linux go build -tags ee -installsuffix cgo -ldflags="-w -s -X main.GitCommit=${GIT_COMMIT}" -o main ./core/cmd/server

# Final stage
FROM alpine:latest

# Install runtime dependencies
RUN apk --no-cache add ca-certificates tzdata ffmpeg curl

# Create non-root user
RUN addgroup -g 1000 -S app && \
    adduser -u 1000 -S app -G app

# Set working directory
WORKDIR /app

# Copy binary from builder
COPY --from=builder /app/main .

# Copy templates and static files
COPY --from=builder /app/core/templates ./core/templates
COPY --from=builder /app/core/static ./core/static

# Change ownership
RUN chown -R app:app /app

# Switch to non-root user
USER app

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Run the binary
CMD ["./main"]
